# Gemini API key for the AI chatbot (optional)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public URL used in outbound links (password-reset emails, etc.)
APP_URL="https://rdharmonymedspa.com"

# Neon / Postgres connection string
POSTGRES_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# Zoho Mail SMTP (outgoing)
SMTP_HOST="smtp.zohocloud.ca"
SMTP_PORT="465"
SMTP_USER="bookings@rdharmonymedspa.com"
SMTP_PASS="REPLACE_WITH_ZOHO_PASSWORD"
MAIL_FROM="RD Harmony Med Spa <bookings@rdharmonymedspa.com>"

# Business inbox that receives booking + enquiry notifications
MAIL_TO_BIZ="bookings@rdharmonymedspa.com"

# Admin portal — seeded on first deploy; change via the "Forgot password" flow
ADMIN_USERNAME="admin"
ADMIN_EMAIL="bookings@rdharmonymedspa.com"
ADMIN_INITIAL_PASSWORD="CHANGE_ME_ON_FIRST_LOGIN"

# Signing secret for admin session tokens (>=32 random chars)
ADMIN_SECRET="REPLACE_WITH_RANDOM_32_PLUS_CHAR_SECRET"

# Shared bearer for Vercel cron job (/api/send-reminders, /api/test-email)
CRON_SECRET="REPLACE_WITH_RANDOM_TOKEN"
